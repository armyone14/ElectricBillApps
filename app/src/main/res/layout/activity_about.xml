<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Profile Picture -->
        <ImageView
            android:id="@+id/imgProfile"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp"
            android:src="@drawable/ic_profile"
            android:contentDescription="Profile picture"
            android:background="@drawable/circle_bg"
            android:padding="4dp"/>

        <!-- Student Info Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="👤 Student Information"
                android:textSize="16sp" android:textStyle="bold"
                android:textColor="@color/primary" android:layout_marginBottom="10dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Full Name: Muhammad Amir Ikhwan bin Mohd Nasir"
                android:textSize="14sp" android:textColor="@color/label_text"
                android:layout_marginBottom="6dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Student ID: 2024764389"
                android:textSize="14sp" android:textColor="@color/label_text"
                android:layout_marginBottom="6dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Course Code: ICT602"
                android:textSize="14sp" android:textColor="@color/label_text"
                android:layout_marginBottom="6dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Course Name: Mobile Technology and Development"
                android:textSize="14sp" android:textColor="@color/label_text"
                android:layout_marginBottom="6dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="© 2024 Muhammad Amir Ikhwan. All Rights Reserved."
                android:textSize="12sp" android:textColor="@color/hint_text"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <!-- App Description + Instructions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ℹ️ About This App"
                android:textSize="16sp" android:textStyle="bold"
                android:textColor="@color/primary" android:layout_marginBottom="10dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ElectricBill Estimator helps you estimate your monthly TNB electricity bill based on Tenaga Nasional Berhad (TNB) tariff rates. It uses block-tiered pricing and supports rebate deductions."
                android:textSize="13sp" android:textColor="@color/label_text"
                android:layout_marginBottom="12dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📖 How to Use:"
                android:textSize="14sp" android:textStyle="bold"
                android:textColor="@color/label_text" android:layout_marginBottom="6dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="1️⃣  Select the billing month from the dropdown.\n2️⃣  Enter the electricity units consumed (1–1000 kWh).\n3️⃣  Slide the rebate bar to set your rebate percentage (0%–5%).\n4️⃣  Tap ⚡ CALCULATE to see your Total Charges and Final Cost.\n5️⃣  Tap 💾 Save to store the record in the database.\n6️⃣  Tap 📋 History from the menu to view all saved bills.\n7️⃣  Tap any record in History to view, edit, or delete it."
                android:textSize="13sp" android:textColor="@color/label_text"/>
        </LinearLayout>

        <!-- GitHub URL -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🔗 Application Website"
                android:textSize="16sp" android:textStyle="bold"
                android:textColor="@color/primary" android:layout_marginBottom="10dp"/>

            <TextView
                android:id="@+id/tvGithubUrl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="github.com/YOUR_USERNAME/ElectricBillApp"
                android:textColor="@color/link_color"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?android:attr/selectableItemBackground"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="(Tap link to open in browser)"
                android:textSize="11sp" android:textColor="@color/hint_text"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>